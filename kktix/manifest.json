{
  "manifest_version": 3,
  "name": "KKTIX 搶票助手",
  "version": "1.0.0",
  "description": "KKTIX 自動搶票工具，支援區域選擇、數量設定與自動流程執行",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://kktix.com/*",
    "https://*.kktix.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KKTIX 搶票助手"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kktix.com/*",
        "https://*.kktix.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
